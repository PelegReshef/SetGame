<UserControl x:Class="SetGame.CardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SetGame"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border BorderThickness="2" Margin="12" BorderBrush="Black"
                    CornerRadius="18" Background="White">
            <Viewbox Margin="2">
                <StackPanel x:Name="CardStackPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center"/>
            </Viewbox>
        </Border>
    </Grid>
</UserControl>
