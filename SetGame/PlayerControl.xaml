<UserControl x:Class="SetGame.PlayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SetGame"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border BorderThickness="2" BorderBrush="Black" CornerRadius="10"
                    Margin="10" Background="AliceBlue">
            <UniformGrid Columns="1">
                <TextBlock x:Name="nameTB" FontSize="15"/>
                <TextBlock x:Name="pointsTB" FontSize="15"/>
            </UniformGrid>
        </Border>
    </Grid>
</UserControl>
