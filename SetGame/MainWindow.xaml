    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/> 
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="cardsGrid" Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <!--card example-->
            <!--<Border BorderThickness="2" BorderBrush="Black" Margin="15" >
                <Viewbox>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path 
                            Data="{StaticResource Squiggle}"
                            Fill="Magenta"
                            Stroke="Black"
                            StrokeThickness="1"
                            Stretch="Uniform"
                            Width="50"
                            Height="80"
                            />
                        
                    </StackPanel>
                </Viewbox>
            </Border>-->
                
        </Grid>
        <Border BorderBrush="#CCDCF8" BorderThickness="3" Grid.Row="0" Grid.Column="1" Background="#EFFCFF">
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <Button x:Name="newGameBtn"  Content="New game" 
                        Style="{StaticResource SidebarButton}" Click="newGameBtn_Click" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource SidebarButton}"
                            Content="Open 3 cards" FontSize="17"
                            Click="ThreeCardsBtn_Click"/>
                    <Button Style="{StaticResource SidebarButton}"
                            Content="End game" FontSize="17"
                            Grid.Column="1"/>

                </Grid>
                
                <!--added grid for vertical alignment-->
                <Grid Background="#CCDCF8" Grid.Row="2" Margin="10">
                    <TextBlock x:Name="outputTBlock"  Text="hello" VerticalAlignment="Center"
                               FontSize="20" TextAlignment="Center"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                    
                </Grid>

                <Grid Grid.Row="3" x:Name="playersGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!--exaple player card-->
                    <!--<Border BorderBrush="Black" BorderThickness="2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="name: blargous"/>
                            <TextBlock Text="point: 100" Grid.Row="1"/>
                        </Grid>
                    </Border>-->
                </Grid>



            </Grid>

        </Border>


    </Grid>
