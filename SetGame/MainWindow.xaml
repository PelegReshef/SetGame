<Window x:Class="SetGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SetGame"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/> 
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <UniformGrid x:Name="cardsGrid" Rows="3" Columns="4" Grid.Row="0" Grid.Column="0">
        </UniformGrid>

        <StackPanel Grid.Row="0" Grid.Column="1">
            
        </StackPanel>
        <Button x:Name="newGameBtn"  Content="New game"
                FontSize="25" VerticalAlignment="Top" Margin="10" />


    </Grid>
</Window>
